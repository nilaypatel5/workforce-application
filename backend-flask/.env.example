## Flask / JWT
# Use a long random value in real deployments
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

## SQL Server (Windows Auth example)
# Replace SERVERNAME\\INSTANCE with your machine/instance name.
# Example:
# DATABASE_URL=mssql+pyodbc://SERVERNAME\\SQLEXPRESS/EmployeeAuth?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes
DATABASE_URL=mssql+pyodbc://SERVERNAME\\INSTANCE/EmployeeAuth?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

                                                                                                                                                                                                            